<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.Views.NodeServiceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI.Views"
    xmlns:model="using:MTCUI.Models"
    xmlns:control="using:MTCUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NodeServiceWindow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <Grid x:Name="AppTitleBar">
            <Image Source="/Assets/icon.ico" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Center" Width="20" Height="20" Margin="8, 4, 0, 0"/>
            <TextBlock Text="Node Service" VerticalAlignment="Center" Margin="32 0 0 0"/>
        </Grid>
        <!-- Top Bar -->
        <Border Grid.Row="1" BorderBrush="#FF243652" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="LORA FLEET MANAGER" FontFamily="Consolas" FontSize="12"
                                CharacterSpacing="200"/>
                    <TextBlock Text="STM32F103 + RAK3172" FontFamily="Consolas" FontSize="10"
                                CharacterSpacing="200"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="NodeCountText" Text="30 NODES REGISTERED" FontFamily="Consolas" FontSize="10"
                               />
                    <Ellipse Width="6" Height="6" />
                </StackPanel>
            </Grid>
        </Border>
        <!-- Network Health Panel -->
        <Border Grid.Row="2" BorderBrush="#FF243652" BorderThickness="0,0,0,1" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,32,0">
                    <TextBlock Text="NETWORK HEALTH" FontFamily="Consolas" FontSize="10"
                                CharacterSpacing="200" Margin="0,0,0,4"/>
                    <TextBlock x:Name="HealthScoreText" Text="75%" FontFamily="Consolas" FontSize="48" FontWeight="Medium"
                               />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" VerticalAlignment="Top" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="ONLINE" FontFamily="Consolas" FontSize="10"
                                    CharacterSpacing="200"/>
                        <TextBlock x:Name="OnlineCount" Text="22" FontFamily="Consolas" FontSize="24"
                                   />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="WARNING" FontFamily="Consolas" FontSize="10"
                                    CharacterSpacing="200"/>
                        <TextBlock x:Name="WarningCount" Text="3" FontFamily="Consolas" FontSize="24"
                                   />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="ERROR" FontFamily="Consolas" FontSize="10"
                                    CharacterSpacing="200"/>
                        <TextBlock x:Name="ErrorCount" Text="2" FontFamily="Consolas" FontSize="24"
                                   />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="OFFLINE" FontFamily="Consolas" FontSize="10"
                                    CharacterSpacing="200"/>
                        <TextBlock x:Name="OfflineCount" Text="3" FontFamily="Consolas" FontSize="24"
                                   />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,0,0">
                    <TextBlock Text="AVG RSSI" FontFamily="Consolas" FontSize="10"
                                CharacterSpacing="200"/>
                    <TextBlock x:Name="AvgRssiText" Text="-82 dBm" FontFamily="Consolas" FontSize="18"
                                HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Main Content: Node Grid + Config Panel -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ConfigColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <!-- Node Grid -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Grid Header -->
                    <Border Grid.Row="0" BorderBrush="#FF243652" BorderThickness="0,0,0,1" Padding="16,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NODE ID" FontFamily="Segoe UI Variable" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="UNIQUE ID" FontFamily="Segoe UI Variable" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="NODE GROUP" FontFamily="Segoe UI Variable" FontSize="11"/>
                            <TextBlock Grid.Column="3" Text="TARGET TYPE" FontFamily="Segoe UI Variable" FontSize="11"/>
                            <TextBlock Grid.Column="4" Text="LIGHT MODE" FontFamily="Segoe UI Variable" FontSize="11"/>
                            <TextBlock Grid.Column="5" Text="RSSI" FontFamily="Segoe UI Variable" FontSize="11"/>
                            <TextBlock Grid.Column="6" Text="SNR" FontFamily="Segoe UI Variable" FontSize="11"/>
                            <TextBlock Grid.Column="7" Text="BATTERY" FontFamily="Segoe UI Variable" FontSize="11"  />
                            <TextBlock Grid.Column="9" Text="ACTION" FontFamily="Segoe UI Variable" FontSize="11" 
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    <!-- Node ListView -->
                    <ListView Grid.Row="1" x:Name="NodeListView" ItemsSource="{x:Bind _nodeServiceVM.Nodes}"
                              Background="Transparent" SelectionMode="Single" SelectionChanged="NodeListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:NodeInfo">
                                <Grid Padding="16,10" ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                        <Ellipse Width="6" Height="6"  VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind NodeId}" FontFamily="Segoe UI Variable" FontSize="13" TextAlignment="Left"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind UniqueId}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"  TextAlignment="Left"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Group}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind TargetType}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind LightMode}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{x:Bind Rssi}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="6" Text="{x:Bind Snr}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="7" Text="{x:Bind BattVoltage}" FontFamily="Segoe UI Variable" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    
                                    <Button Grid.Column="9" Content="CONFIG" Click="ConfigButton_Click"  Tag="{x:Bind NodeId}"
                                            HorizontalAlignment="Right" FontFamily="Segoe UI Variable" FontSize="10"
                                            Background="Transparent" BorderBrush="#FF243652"
                                            Padding="10,4"
                                            CharacterSpacing="200"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>

            <!-- Node Config Panel -->
            <Border Grid.Column="1" x:Name="ConfigPanel" BorderBrush="#FF243652"
                    BorderThickness="1,0,0,0" 
                    Visibility="Collapsed" Width="320">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Config Header -->
                    <Border Grid.Row="0" BorderBrush="#FF243652" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <TextBlock Text="NODE " FontFamily="Consolas" FontSize="13"/>
                            <TextBlock x:Name="ConfigNodeName" Margin="40 0 0 0" Text="{x:Bind _nodeServiceVM.SelectedNode.NodeId}" FontFamily="Consolas" FontSize="13"/>
                            <Button Content="CLOSE" Click="CloseConfig_Click"  HorizontalAlignment="Right"
                                    FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent" BorderThickness="0"
                                     CharacterSpacing="200"/>
                        </Grid>
                    </Border>

                    <!-- Config Content -->
                    <ScrollViewer Grid.Row="1" Padding="16">
                        <StackPanel Spacing="16">
                            <!-- Identity Section -->
                            <StackPanel>
                                <Border  BorderThickness="0,0,0,1" Padding="0,0,0,4" Margin="0,0,0,8">
                                    <TextBlock Text="IDENTITY" FontSize="10" FontFamily="Segoe UI Variable"/>
                                </Border>
                                <control:InfoRow x:Name="DevId" Label="DevId" />
                                <control:InfoRow x:Name="DevEUIRow" Label="DevEUI"/>
                            </StackPanel>

                            <!-- Telemetry Section -->
                            <StackPanel>
                                <Border BorderBrush="#FF243652" BorderThickness="0,0,0,1" Padding="0,0,0,4" Margin="0,0,0,8">
                                    <TextBlock Text="TELEMETRY"  FontSize="10" CharacterSpacing="200"/>
                                </Border>
                                
                            </StackPanel>

                            <!-- Downlink Commands -->
                            <StackPanel>
                                <Border  BorderThickness="0,0,0,1" Padding="0,0,0,4" Margin="0,0,0,8">
                                    <TextBlock Text="DOWNLINK COMMANDS"  FontSize="10"
                                                CharacterSpacing="200"/>
                                </Border>

                                <TextBlock Text="SET TX INTERVAL" FontFamily="Segoe UI Variable" FontSize="10"
                                            CharacterSpacing="200" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Content="60S" Tag="60" 
                                            FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                             Padding="10,4" CharacterSpacing="200"/>
                                    <Button Content="120S" Tag="120" 
                                            FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                             Padding="10,4" CharacterSpacing="200"/>
                                    <Button Content="5M" Tag="300" 
                                            FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                            Padding="10,4" CharacterSpacing="200"/>
                                    <Button Content="10M" Tag="600" 
                                            FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                            
                                             Padding="10,4" CharacterSpacing="200"/>
                                    <Button Content="15M" Tag="900" 
                                            FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                            
                                             Padding="10,4" CharacterSpacing="200"/>
                                </StackPanel>

                                <Button Content="REBOOT NODE"  Margin="0,12,0,0"
                                        FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                         HorizontalAlignment="Stretch"
                                        Padding="12,6"
                                        HorizontalContentAlignment="Left" CharacterSpacing="200"/>
                                <Button Content="REQUEST STATUS"  Margin="0,6,0,0"
                                        FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                         HorizontalAlignment="Stretch"
                                         Padding="12,6"
                                        HorizontalContentAlignment="Left" CharacterSpacing="200"/>
                                <Button Content="REJOIN NETWORK"  Margin="0,6,0,0"
                                        FontFamily="Segoe UI Variable" FontSize="10" Background="Transparent"
                                         HorizontalAlignment="Stretch"
                                         Padding="12,6"
                                        HorizontalContentAlignment="Left" CharacterSpacing="200"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            
        </Grid>
    </Grid>
</Window>
