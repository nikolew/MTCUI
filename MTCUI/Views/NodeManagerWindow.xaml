<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.Views.NodeManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:models="using:MTCUI.Models"
    Title="NodeManagerWindow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Padding="10 20 10 10">
            <ListView x:Name="MyList" ItemsSource="{x:Bind NodeManagerVM.Items}">
                
                <!-- HEADER -->
                <ListView.Header>
                    <Grid Padding="10,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Node ID" Grid.Column="0" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Unique ID" Grid.Column="1" FontWeight="Bold" Margin="20 0 0 0" TextAlignment="Center"/>
                        <TextBlock Text="X" Grid.Column="2" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Y" Grid.Column="3" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Вид цел" Grid.Column="4" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Разстояние" Grid.Column="5" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Група" Grid.Column="6" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Rssi" Grid.Column="7" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Snr" Grid.Column="8" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Status" Grid.Column="9" FontWeight="Bold" TextAlignment="Center"/>
                        
                    </Grid>
                </ListView.Header>

                <!-- ROW TEMPLATE -->
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ItemModel">

                        <Grid Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind TargetId}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind UniqueId}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Position.X}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Position.Y}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox Grid.Column="4"
                                ItemsSource="{Binding ElementName=MyList, Path=DataContext.TargetTypes}"
                                SelectedItem="{x:Bind TargetType, Mode=TwoWay}"
                                Width="150" />
                            <TextBox Text="{x:Bind Distance, Mode=TwoWay}" Grid.Column="5" TextAlignment="Center" Margin="0 0 10 0"/>
                            <ComboBox Grid.Column="6"
                                ItemsSource="{Binding ElementName=MyList, Path=DataContext.TargetGroups}"
                                SelectedItem="{x:Bind Group, Mode=TwoWay}"
                                Width="150" />
                            <StackPanel Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind Rssi, Mode=TwoWay}"  TextAlignment="Center" Margin="0 0 10 0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind Snr, Mode=TwoWay}"  TextAlignment="Center" Margin="0 0 10 0"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind Status}" Grid.Column="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10,0,10" 
                    VerticalAlignment="Bottom">
            <Button Content="Add Node" Width="110" Margin="5" />
            <Button Content="Remove Node" Width="110" Margin="5" />
            <Button Content="Load Nodes" Width="110" Margin="5" />
            <Button Content="Save Nodes" Width="110" Margin="5" Command="{x:Bind NodeManagerVM.SaveCommand}"/>
            
        </StackPanel>

    </Grid>
</Window>
