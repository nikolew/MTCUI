<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.Views.GroupManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="GroupManager">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid x:Name="AppTitleBar">
            <Image Source="/Assets/icon.ico" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Center" Width="20" Height="20" Margin="8, 4, 0, 0"/>
            <TextBlock Text="Групи" VerticalAlignment="Center" Margin="32 0 0 0"/>
        </Grid>

        <StackPanel Grid.Row="1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Добави група" Margin="10" Width="120" Height="30" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddNewGroupCommand}" />
                <TextBox Width="120" Height="30" Text="{Binding NewGroupName, Mode=TwoWay}"/>
                <Button Width="30" Height="30" Margin="10 0 0 0" Style="{StaticResource ButtonStyle1}" BorderBrush="Gray" BorderThickness="1">
                    <Button.Background>
                        <SolidColorBrush x:Name="SelectedBrush" Color="{Binding ColorBrush, Mode=TwoWay}" Opacity="0.6"/>
                    </Button.Background>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <ColorPicker x:Name="Picker"
                                IsAlphaEnabled="False"
                                ColorChanged="Picker_ColorChanged"/>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Content="Изтрий група" Command="{Binding DeleteGroupCommand}" Margin="40 0 0 0"
                        Width="120" Height="30" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>

            <ListView BorderBrush="Black" BorderThickness="1" Height="500"
                Margin="10 20 10 10"
                ItemsSource="{Binding Groups}" 
                SelectedItem="{Binding SelectedGroup, Mode=TwoWay}" >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <!--<StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Id}" VerticalAlignment="Center"/>
                            </StackPanel>-->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Rectangle Width="40" Height="20" Fill="{Binding GroupColor}" Margin="5"  Opacity="0.6"/>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Window>
