<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.Views.SchedulerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MTCUI.ViewModels"
    mc:Ignorable="d"
    Title="SchedulerWindow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar">
            <Image Source="/Assets/icon.ico" 
            HorizontalAlignment="Left" 
            VerticalAlignment="Center" Width="20" Height="20" Margin="8, 4, 0, 0"/>
            <TextBlock Text="График" VerticalAlignment="Center" Margin="32 0 0 0"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0 20 0 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100"  />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="10" Orientation="Vertical">
                    <TextBlock Text="Групи" Margin="0 0 0 10"/>
                    <ListBox BorderBrush="CornflowerBlue" BorderThickness="1"
                        Width="120" Height="350" 
                        ItemsSource="{Binding Groups}" 
                        SelectedItem="{Binding SelectedGroup, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="20" Fill="{Binding GroupColor}" Margin="5" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                <StackPanel Grid.Column="1" >
                    <TextBlock Text="Време:" Margin="0,10,0,0" />
                    <TextBox Text="{Binding NewTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Margin="0,5,0,0" TextChanging="TextBox_TextChanging" MaxLength="5"
                        IsEnabled="{Binding ControlEnabled, Mode=OneWay}"/>
                    <Button Content="Добави време" Margin="0,10,0,0" Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="{Binding ControlEnabled , Mode=OneWay}" Width="100" Height="30"
                        Command="{Binding AddTimeAsyncCommand}" />
                </StackPanel >
                <StackPanel Grid.Column="2" Margin="10">
                    <TextBlock Text="Времена в група" Margin="0 0 0 10"/>
                    <ListBox BorderBrush="CornflowerBlue" BorderThickness="1"
                        Width="120" Height="350"
                        ItemsSource="{Binding Times}" 
                        SelectedItem="{Binding SelectedTime, Mode=TwoWay}" >
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding }" FontWeight="Bold"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Изтрий време" Margin="0 10 0 0" Width="120"
                        Command="{Binding DeleteTimeAsyncCommand}" 
                        IsEnabled="{Binding BtnDeleteEnabled, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="20 10 0 0">
                    <TextBlock Text="Всички времена" Margin="0 0 0 10"/>
                    <ListBox BorderBrush="CornflowerBlue" BorderThickness="1"
                        Width="120" Height="350" ItemsSource="{Binding AllTimes}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding }" FontWeight="Bold"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
