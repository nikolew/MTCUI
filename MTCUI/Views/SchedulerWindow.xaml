<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.Views.SchedulerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MTCUI.ViewModels"
    mc:Ignorable="d"
    Title="GroupManagerWindow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="100"  />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10" Orientation="Vertical">
            <ListBox  BorderBrush="Black" BorderThickness="1"
                Width="120" Height="350" 
                ItemsSource="{Binding Groups}" 
                SelectedItem="{Binding SelectedGroup, Mode=TwoWay}" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <!--<TextBlock Text="Group Name:" Margin="0,10,0,0"  Width="120"/>
            <TextBox Text="{Binding NewGroupName, Mode=TwoWay}" Margin="0,5,0,0"  Width="120"/>
            <Button Content="Add Group" Margin="0,10,0,0"  Width="120" Height="30" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding AddNewGroupCommand}" 
                    CommandParameter="{Binding NewGroupName}"/>
            <Button Content="Delete Group" Command="{Binding DeleteGroupAsyncCommand}" Margin="0 5 0 0"
                    Width="120" Height="30" Style="{StaticResource PrimaryButtonStyle}"/>-->
           
             
        </StackPanel>
        <StackPanel Grid.Column="1" >
            <TextBlock Text="Time:" Margin="0,10,0,0" />
            <TextBox Text="{Binding NewTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5,0,0" TextChanging="TextBox_TextChanging" MaxLength="5"
                     IsEnabled="{Binding ControlEnabled, Mode=OneWay}"/>
            <Button Content="Add Time" Margin="0,10,0,0" Style="{StaticResource PrimaryButtonStyle}"
                    IsEnabled="{Binding ControlEnabled , Mode=OneWay}" Width="100" Height="30"
                    Command="{Binding AddTimeAsyncCommand}" />
        </StackPanel >
        <StackPanel Grid.Column="2" Margin="10">
            <ListBox BorderBrush="Black" BorderThickness="1"
                Width="120" Height="350"
                ItemsSource="{Binding Times}" 
                SelectedItem="{Binding SelectedTime, Mode=TwoWay}" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding }" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Content="Delete time" Margin="0 10 0 0" Width="120"
                    Command="{Binding DeleteTimeAsyncCommand}" 
                    IsEnabled="{Binding BtnDeleteEnabled, Mode=OneWay}"/>
        </StackPanel>
        <StackPanel Grid.Column="3" Margin="20 10 0 0">
            <ListBox BorderBrush="Black" BorderThickness="1"
                     Width="120" Height="350" ItemsSource="{Binding AllTimes}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding }" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>
