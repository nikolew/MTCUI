<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.Views.NodeEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NodeEditWindow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="NodeEditGrid">

        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid x:Name="AppTitleBar">
            <Image Source="/Assets/icon.ico" HorizontalAlignment="Left" VerticalAlignment="Center"
                Width="20" Height="20" Margin="8, 4, 0, 0"/>
            <TextBlock Text="Node Edit" VerticalAlignment="Center" Margin="32 0 0 0"/>
        </Grid>
        
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="10 5 0 5" Orientation="Horizontal">
                <TextBlock Text="Target Id:" Margin="5 0 0 0" FontWeight="Bold"/>
                <TextBlock Text="{Binding Item.TargetId}" Margin="10 0 0 0"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="10 5 0 5">
                <TextBlock Text="Target Type" Margin="5 0 0 0"/>
                <ComboBox Grid.Column="4"
                    ItemsSource="{Binding TargetTypes}"
                    SelectedItem="{Binding TargetType, Mode=TwoWay}"
                    Width="120" />
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="10 5 0 5">
                <TextBlock Text="Group" Margin="5 0 0 0"/>
                <ComboBox Grid.Column="4"
                    ItemsSource="{Binding TargetGroups}"
                    SelectedItem="{Binding Group, Mode=TwoWay}"
                    Width="120" />
            </StackPanel>
            <StackPanel Grid.Row="3" Margin="10 5 0 5">
                <TextBlock Text="Light Mode" Margin="5 0 0 0"/>
                <ComboBox Grid.Column="4"
                    ItemsSource="{Binding LightModes}"
                    SelectedItem="{Binding LightMode, Mode=TwoWay}"
                    Width="120" />
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Save" Width="100"  Margin="0 0 10 0" Command="{Binding SaveCommand}"/>
            <Button Content="Close" Width="100" Margin="0 0 10 0"/>
        </StackPanel>
    </Grid>
</Window>
