<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="TargetText" TargetType="TextBlock" >
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Opacity" Value="0.9"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TargetBorder" TargetType="Border">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <!--<Setter Property="Background" Value="LightBlue"/>-->
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="20"/>
    </Style>

    <Style x:Key="TargetOffline"  TargetType="Polygon">
        <Setter Property="Fill" Value="LightGray"/>
        <Setter Property="Stroke" Value="Gray"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>
    
    <Style x:Key="TargetRaised"  TargetType="Polygon">
        <Setter Property="Fill" Value="DarkSeaGreen"/>
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <Style x:Key="TargetHit"  TargetType="Polygon">
        <Setter Property="Fill" Value="IndianRed"/>
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>


    <Style x:Key="TargetFolded"  TargetType="Polygon">
        <Setter Property="Fill" Value="LightGray"/>
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <DataTemplate x:Key="Target8">
        <Canvas Margin="15 0 0 5">
            <Polygon Style="{Binding TargetStateView}"
                Points="10 100, 0 75, 0 30, 15 30,15 15, 35 15, 35 30, 50 30, 50 75, 40 100"                             
                Opacity="0.8">
            </Polygon>
            <Border Style="{StaticResource TargetBorder}" Background="{Binding GroupColor}" Margin="10 70 0 0" >
                <StackPanel>
                    <TextBlock Style="{StaticResource TargetText}" 
                               Text="{Binding Node.NodeId}"/>
                </StackPanel>
            </Border>
        </Canvas>
    </DataTemplate>

    <DataTemplate x:Key="Target10">
        <Canvas Margin="10 0 0 5">
            <Polygon Style="{Binding TargetStateView}"
            Points="0 100, 0 75, 10 75, 10 65, 30 65, 30 48, 50 48, 50 60, 60 60, 60 100"                             
            Opacity="0.8">
            </Polygon>
            <Border Style="{StaticResource TargetBorder}" Margin="18 70 0 0" Background="{Binding GroupColor}" >
                <StackPanel>
                    <TextBlock Style="{StaticResource TargetText}" 
                           Text="{Binding Node.NodeId}"/>
                </StackPanel>
            </Border>
        </Canvas>
    </DataTemplate>

    <DataTemplate x:Key="Target10A">
        <Canvas Margin="0 0 0 5">
            <Polygon
                Style="{Binding TargetStateView}"
                Points="0 100, 0 65, 15 65, 15 50, 35 50, 35 60, 50 45, 50 30, 70 30, 70 45, 80 45, 80 100"                             
                Opacity="0.8">
            </Polygon>
            <Border Style="{StaticResource TargetBorder}" Margin="25 70 0 0" Background="{Binding GroupColor}" >
                <StackPanel>
                    <TextBlock Style="{StaticResource TargetText}" 
                       Text="{Binding Node.NodeId}"/>
                </StackPanel>
            </Border>
        </Canvas>
    </DataTemplate>

    <DataTemplate x:Key="Target6">
        <Canvas Margin="15 0 0 5">
            <Polygon
                Style="{Binding TargetStateView}"
                Points="0 100, 0 65, 15 65, 15 50, 35 50, 35 65, 50 65, 50 100"                             
                Opacity="0.8">
            </Polygon>
            <Border Style="{StaticResource TargetBorder}" Margin="10 70 0 0" Background="{Binding GroupColor}" >
                <StackPanel>
                    <TextBlock Style="{StaticResource TargetText}" 
                        Text="{Binding Node.NodeId}"/>
                </StackPanel>
            </Border>
        </Canvas>
    </DataTemplate>

    <DataTemplate x:Key="Target7">
        <Canvas Margin="15 0 0 5">
            <Polygon
                Style="{Binding TargetStateView}"
                Points="0 100, 0 40, 15 40,15 25, 35 25, 35 40, 50 40, 50 100"                             
                Opacity="0.8">
            </Polygon>
            <Border Style="{StaticResource TargetBorder}" Margin="10 70 0 0" Background="{Binding GroupColor}" >
                <StackPanel>
                    <TextBlock Style="{StaticResource TargetText}" 
                        Text="{Binding Node.NodeId}"/>
                </StackPanel>
            </Border>
        </Canvas>
    </DataTemplate>

    <DataTemplate x:Key="Default">
        <Canvas Margin="15 0 0 5">
            <Polygon Style="{Binding TargetStateView}" 
                Points="0 100, 0 25, 50 25, 50 100"                             
                Opacity="0.8">
            </Polygon>
            <Border Style="{StaticResource TargetBorder}" Margin="10 70 0 0" >
                <StackPanel>
                    <TextBlock Style="{StaticResource TargetText}" 
                        Text="{Binding Node.NodeId}"/>
                </StackPanel>
            </Border>
            <ToolTipService.ToolTip>
                <ToolTip>
                    <StackPanel>
                        <TextBlock>Батерия: ОК</TextBlock>
                        <TextBlock>Разстояние: 150м</TextBlock>
                    </StackPanel>
                </ToolTip>
            </ToolTipService.ToolTip>
        </Canvas>
    </DataTemplate>

</ResourceDictionary>
