<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MTCUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MTCUI"
    xmlns:control="using:MTCUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:vm="using:MTCUI.ViewModels"
    xmlns:controls="using:MTCUI.Controls"
    Title="MTCUI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>
        <Grid x:Name="AppTitleBar">
            <Image Source="/Assets/icon.ico" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Center"
                   Width="20"
                   Height="20"
                   Margin="8, 4, 0, 0"/>
            
            <TextBlock Text="MTCUI"
                       VerticalAlignment="Center"
                       Margin="32 0 0 0"/>
        </Grid>

        <StackPanel Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                    <MenuBar  VerticalAlignment="Top" HorizontalAlignment="Left" >
                        <MenuBarItem Title="File" FontFamily="Segoe UI Variable" FontSize="14">
                            <MenuFlyoutItem Text="Load Scene" FontFamily="Segoe UI Variable" Click="LoadNodes_Click" />
                            <MenuFlyoutItem Text="Save" Click="SaveScene_Click" />
                        </MenuBarItem>
                        <MenuBarItem Title="View" FontFamily="Segoe UI Variable" FontSize="14">
                            <MenuFlyoutItem Text="Timer" FontFamily="Segoe UI Variable" Click="ShowTimer_Click"/>
                            <MenuFlyoutItem Text="Group" FontFamily="Segoe UI Variable" Click="ShowGroup_Click"/>
                        </MenuBarItem>
                        <MenuBarItem Title="Config" FontFamily="Segoe UI Variable" FontSize="14">
                            <MenuFlyoutItem Text="Node Manager" Click="NodeManager_Click" />
                            <MenuFlyoutItem Text="Scheduler" Click="Scheduler_Click" />
                            <MenuFlyoutItem Text="Reset Master" Click="ResetMaster_Click"/>
                        </MenuBarItem>
                        <MenuBarItem>
                            <MenuFlyoutItem Text="Reset" Click="Reset_Click" />
                        </MenuBarItem>
                    </MenuBar>
                </StackPanel>
                
            </Grid>
        </StackPanel>
        
